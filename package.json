{
  "name": "my-cv",
  "version": "1.0.0",
  "description": "Personal CV Website with Tailwind CSS Dark Mode",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build:css": "npx @tailwindcss/cli -i ./src/input.css -o ./public/output.css",
    "watch:css": "npx @tailwindcss/cli -i ./src/input.css -o ./public/output.css --watch",
    "dev": "npm run build:css && node server.js"
  },
  "keywords": ["cv", "portfolio", "tailwindcss"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/cli": "^4.0.0"
  }
}